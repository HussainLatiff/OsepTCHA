// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Configuration {
  site_key         String   @id @default(uuid())
  secret_key       String   @unique @default(uuid())
  allowed_sets     Json     // Stored as JSON array, e.g., ["emoji_challenge_1"]
  layout_type      String   // "grid" or "dynamic"
  max_items        Int
  zkp_max_velocity Float
  zkp_min_tremor   Float
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
